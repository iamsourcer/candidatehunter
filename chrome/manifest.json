{
  "manifest_version": 3,
  "name": "CandidateHunter",
  "version": "1.9",
  "description": "AI-powered candidate screening for LinkedIn profiles.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html"
  }
}
